<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      iRate ships NON-sandboxed by default: it is a personal fullscreen culling
      tool that must reach arbitrary external card readers / NAS shares, and TCC
      already gates those with a system prompt on first access. The security-
      scoped bookmark it stores (see FolderAccess in main.mm) still round-trips
      the chosen folder so re-launch skips the picker.

      To ship a sandboxed build (e.g. for the App Store), flip these on and add
      com.apple.security.app-sandbox — the FolderAccess layer already creates and
      resolves bookmarks WITH the security scope, so no code change is needed.
    -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
</dict>
</plist>
